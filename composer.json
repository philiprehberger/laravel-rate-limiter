{
    "name": "philiprehberger/laravel-rate-limiter",
    "description": "Advanced rate limiting with sliding window, token bucket, and per-entity controls for Laravel.",
    "type": "library",
    "keywords": [
        "laravel",
        "rate-limiting",
        "sliding-window",
        "token-bucket",
        "throttle",
        "middleware"
    ],
    "homepage": "https://github.com/philiprehberger/laravel-rate-limiter",
    "license": "MIT",
    "authors": [
        {
            "name": "Philip Rehberger",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0",
        "illuminate/cache": "^11.0|^12.0",
        "illuminate/routing": "^11.0|^12.0",
        "illuminate/http": "^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "phpunit/phpunit": "^11.0",
        "laravel/pint": "^1.0",
        "larastan/larastan": "^2.9",
        "phpstan/phpstan": "^1.12|^2.0"
    },
    "autoload": {
        "psr-4": {
            "PhilipRehberger\\RateLimiter\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PhilipRehberger\\RateLimiter\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "PhilipRehberger\\RateLimiter\\RateLimiterServiceProvider"
            ],
            "aliases": {
                "RateLimit": "PhilipRehberger\\RateLimiter\\Facades\\RateLimit"
            }
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "scripts": {
        "test": "vendor/bin/phpunit",
        "pint": "vendor/bin/pint",
        "stan": "vendor/bin/phpstan analyse --memory-limit=512M"
    }
}
